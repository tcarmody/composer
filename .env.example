# Composer configuration. Copy to .env and fill in.

# Auth for the internal API (frontend -> backend). Leave empty for local dev.
AUTH_API_KEY=

# Auth for the public ingest API (DataPoints -> Composer). Leave empty for local dev.
COMPOSER_INGEST_KEY=

# LLM provider (not used until Phase 3 / Ask mode)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# VOYAGE_API_KEY=
# LLM_PROVIDER=anthropic
# LLM_MODEL=

# Server
PORT=5006
DB_PATH=./data/composer.db
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
